<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wish Lanterns</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(to bottom, #0c1445, #1a237e, #4a148c);
            height: 100vh;
            overflow: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
        }

        #canvas-container {
            position: relative;
            width: 100%;
            height: 80vh;
            overflow: hidden;
        }

        canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        #title {
            text-align: center;
            margin-bottom: 20px;
            font-size: 2.5rem;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
            z-index: 10;
        }

        #instructions {
            text-align: center;
            margin-bottom: 20px;
            font-size: 1.2rem;
            max-width: 600px;
            z-index: 10;
        }

        #controls {
            display: flex;
            gap: 20px;
            margin-top: 20px;
            z-index: 10;
        }

        button {
            background: rgba(255, 255, 255, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 1rem;
            backdrop-filter: blur(5px);
            transition: all 0.3s ease;
        }

        button:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.05);
        }

        #particle-count {
            margin-top: 10px;
            text-align: center;
            font-size: 1rem;
        }

        #audio-info {
            position: absolute;
            bottom: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.5);
            padding: 10px;
            border-radius: 10px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <h1 id="title">Wish Lanterns</h1>
    <p id="instructions">Click or tap anywhere to release a lantern. The more you interact, the more magical the experience becomes.</p>
    
    <div id="canvas-container">
        <canvas id="particleCanvas"></canvas>
        <canvas id="lightCanvas"></canvas>
    </div>
    
    <div id="controls">
        <button id="playButton">Play Sound</button>
        <button id="pauseButton">Pause Sound</button>
        <button id="resetButton">Reset</button>
    </div>
    
    <div id="particle-count">Lanterns released: <span id="count">0</span></div>
    
    <div id="audio-info">
        Audio: <span id="audio-status">Ready</span>
    </div>

    <script>
        // Audio context and state
        let audioContext;
        let isPlaying = false;
        let oscillators = [];
        let gainNode = null;
        let filter = null;
        let soundStartTime = 0;

        // Canvas setup
        const particleCanvas = document.getElementById('particleCanvas');
        const lightCanvas = document.getElementById('lightCanvas');
        const particleCtx = particleCanvas.getContext('2d');
        const lightCtx = lightCanvas.getContext('2d');
        const countElement = document.getElementById('count');
        const playButton = document.getElementById('playButton');
        const pauseButton = document.getElementById('pauseButton');
        const resetButton = document.getElementById('resetButton');
        const audioStatus = document.getElementById('audio-status');

        // Set canvas sizes
        function resizeCanvases() {
            const container = document.getElementById('canvas-container');
            particleCanvas.width = container.clientWidth;
            particleCanvas.height = container.clientHeight;
            lightCanvas.width = container.clientWidth;
            lightCanvas.height = container.clientHeight;
        }

        // Initialize canvases
        resizeCanvases();
        window.addEventListener('resize', resizeCanvases);

        // Lantern particle class
        class Lantern {
            constructor(x, y) {
                this.x = x;
                this.y = y;
                this.size = Math.random() * 15 + 5;
                this.speed = Math.random() * 0.5 + 0.1;
                this.angle = Math.random() * Math.PI * 2;
                this.alpha = 1;
                this.color = this.getRandomColor();
                this.pulse = 0;
                this.pulseDirection = 1;
                this.lifetime = 0;
                this.maxLifetime = Math.random() * 200 + 100;
                this.hue = Math.random() * 360;
                this.saturation = 80 + Math.random() * 20;
                this.lightness = 50 + Math.random() * 30;
                this.wave = 0;
            }

            getRandomColor() {
                return `hsla(${Math.random() * 360}, 80%, 60%, 0.8)`;
            }

            update() {
                this.lifetime++;
                this.y -= this.speed;
                this.x += Math.sin(this.wave) * 0.2;
                this.wave += 0.05;

                // Pulsing effect
                this.pulse += 0.03 * this.pulseDirection;
                if (this.pulse > 1 || this.pulse < 0) {
                    this.pulseDirection *= -1;
                }

                // Fade out
                this.alpha = 1 - (this.lifetime / this.maxLifetime);

                // Update color
                this.hue = (this.hue + 0.1) % 360;
                this.color = `hsla(${this.hue}, ${this.saturation}%, ${this.lightness}%, ${this.alpha})`;

                return this.lifetime < this.maxLifetime;
            }

            draw(ctx) {
                const pulseSize = this.size * (1 + this.pulse * 0.3);
                
                ctx.beginPath();
                ctx.arc(this.x, this.y, pulseSize, 0, Math.PI * 2);
                ctx.fillStyle = this.color;
                ctx.fill();

                // Add glow effect
                ctx.beginPath();
                ctx.arc(this.x, this.y, pulseSize * 2, 0, Math.PI * 2);
                const gradient = ctx.createRadialGradient(
                    this.x, this.y, pulseSize,
                    this.x, this.y, pulseSize * 2
                );
                gradient.addColorStop(0, this.color);
                gradient.addColorStop(1, 'transparent');
                ctx.fillStyle = gradient;
                ctx.fill();
            }
        }

        // Particle system
        let lanterns = [];
        let lanternCount = 0;

        // Create a new lantern
        function createLantern(x, y) {
            lanterns.push(new Lantern(x, y));
            lanternCount++;
            countElement.textContent = lanternCount;
        }

        // Animation loop
        function animate() {
            // Clear canvases
            particleCtx.clearRect(0, 0, particleCanvas.width, particleCanvas.height);
            lightCtx.clearRect(0, 0, lightCanvas.width, lightCanvas.height);

            // Draw background glow
            drawBackground();

            // Update and draw lanterns
            for (let i = lanterns.length - 1; i >= 0; i--) {
                const lantern = lanterns[i];
                if (!lantern.update()) {
                    lanterns.splice(i, 1);
                } else {
                    lantern.draw(particleCtx);
                }
            }

            // Draw light effects
            drawLightEffects();

            requestAnimationFrame(animate);
        }

        // Draw background glow
        function drawBackground() {
            const gradient = particleCtx.createRadialGradient(
                particleCanvas.width / 2, particleCanvas.height / 2,
                0,
                particleCanvas.width / 2, particleCanvas.height / 2,
                Math.max(particleCanvas.width, particleCanvas.height) / 2
            );
            gradient.addColorStop(0, 'rgba(100, 100, 200, 0.1)');
            gradient.addColorStop(1, 'rgba(20, 20, 60, 0.5)');
            particleCtx.fillStyle = gradient;
            particleCtx.fillRect(0, 0, particleCanvas.width, particleCanvas.height);
        }

        // Draw light effects
        function drawLightEffects() {
            // Create a subtle light effect
            lightCtx.globalCompositeOperation = 'lighter';
            lightCtx.fillStyle = 'rgba(255, 255, 255, 0.05)';
            for (let i = 0; i < 5; i++) {
                const x = Math.sin(Date.now() / 2000 + i) * particleCanvas.width / 2 + particleCanvas.width / 2;
                const y = Math.cos(Date.now() / 1500 + i) * particleCanvas.height / 2 + particleCanvas.height / 2;
                const radius = 50 + Math.sin(Date.now() / 1000 + i) * 30;
                lightCtx.beginPath();
                lightCtx.arc(x, y, radius, 0, Math.PI * 2);
                lightCtx.fill();
            }
            lightCtx.globalCompositeOperation = 'source-over';
        }

        // Audio synthesis functions
        function initAudio() {
            if (!audioContext) {
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                audioStatus.textContent = 'Initialized';
            }
        }

        function playSound() {
            if (!audioContext) {
                initAudio();
            }

            // Create audio nodes
            const oscillator1 = audioContext.createOscillator();
            const oscillator2 = audioContext.createOscillator();
            const oscillator3 = audioContext.createOscillator();
            gainNode = audioContext.createGain();
            filter = audioContext.createBiquadFilter();

            // Configure oscillator
            oscillator1.type = 'sine';
            oscillator2.type = 'sine';
            oscillator3.type = 'sawtooth';
            oscillator1.frequency.setValueAtTime(220, audioContext.currentTime);
            oscillator2.frequency.setValueAtTime(330, audioContext.currentTime);
            oscillator3.frequency.setValueAtTime(110, audioContext.currentTime);

            // Configure filter
            filter.type = 'lowpass';
            filter.frequency.setValueAtTime(800, audioContext.currentTime);

            // Configure gain envelope
            gainNode.gain.setValueAtTime(0, audioContext.currentTime);
            gainNode.gain.linearRampToValueAtTime(0.3, audioContext.currentTime + 0.1);
            gainNode.gain.linearRampToValueAtTime(0.1, audioContext.currentTime + 0.3);
            gainNode.gain.linearRampToValueAtTime(0, audioContext.currentTime + 0.5);

            // Connect nodes
            oscillator.connect(filter);
            filter.connect(gainNode);
            gainNode.connect(audioContext.destination);

            // Start oscillator
            oscillator.start(audioContext.currentTime);
            oscillator.stop(audioContext.currentTime + 0.5);

            // Update status
            audioStatus.textContent = 'Playing';
            isPlaying = true;

            // Reset status after sound finishes
            setTimeout(() => {
                audioStatus.textContent = 'Ready';
                isPlaying = false;
            }, 500);
        }

        function stopSound() {
            if (oscillator) {
                oscillator.stop();
                oscillator = null;
                audioStatus.textContent = 'Stopped';
            }
        }

        function resetAudio() {
            if (audioContext) {
                audioContext.close();
                audioContext = null;
                audioStatus.textContent = 'Reset';
                isPlaying = false;
            }
        }

        // Event listeners
        document.addEventListener('click', (e) => {
            const rect = particleCanvas.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            createLantern(x, y);
            playSound();
        });

        document.addEventListener('touchstart', (e) => {
            e.preventDefault();
            const rect = particleCanvas.getBoundingClientRect();
            const touch = e.touches[0];
            const x = touch.clientX - rect.left;
            const y = touch.clientY - rect.top;
            createLantern(x, y);
            playSound();
        });

        playButton.addEventListener('click', () => {
            playSound();
        });

        pauseButton.addEventListener('click', () => {
            stopSound();
        });

        resetButton.addEventListener('click', () => {
            resetAudio();
            lanterns = [];
            lanternCount = 0;
            countElement.textContent = lanternCount;
        });

        // Start animation
        animate();

        // Initial sound test
        window.addEventListener('load', () => {
            // We'll wait for user interaction to initialize audio
            // This is required for modern browsers
        });
    </script>
</body>
</html>
